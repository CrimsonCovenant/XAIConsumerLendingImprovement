# XAI Consumer Lending .gitignore

# Data (186 GB+ of HMDA CSVs and processed parquets)
data/

# Model artifacts (trained weights, pickles, checkpoints)
outputs/models/**/*.pkl
outputs/models/**/*.pt
outputs/models/**/*.npy
outputs/models/**/*.csv

# Generated outputs (regenerated by the pipeline)
outputs/figures/
outputs/visualizations/
outputs/explanations/
outputs/reports/
outputs/audit_artifacts/
outputs/drift/
outputs/fairness/

# Run manifests (regenerated each run)
outputs/models/**/_run_manifest.json
outputs/models/**/ensemble_meta.json
outputs/models/**/feature_columns.json

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb

# Environment and dependency locks
*.egg-info/
*.egg
dist/
build/
.eggs/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
._*

# MLflow tracking (local runs)
mlruns/

# Optuna databases
*.db

# Misc
*.log
*.tmp
.env
.env.*
